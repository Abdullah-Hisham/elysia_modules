{
  "name": "elysia-modules",
  "version": "0.2.0",
  "description": "NestJS-like modular architecture for Elysia.js — modules, providers, controllers, DI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "elysia-modules": "./bin/elysia-modules.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "elysia",
    "bun",
    "nestjs",
    "modules",
    "dependency-injection",
    "decorators",
    "controllers",
    "providers",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/elysia-modules"
  },
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/elysia-modules/issues"
  },
  "homepage": "https://github.com/YOUR_USERNAME/elysia-modules#readme",
  "peerDependencies": {
    "elysia": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true }
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "elysia": "^1.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
